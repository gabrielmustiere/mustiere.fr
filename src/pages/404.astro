---
import SiteLayout from '../layouts/SiteLayout.astro';
---

<SiteLayout
  title="Page introuvable"
  description="La page demandée n'existe pas ou a été déplacée."
  noindex
  current="blog"
>
  <main
    id="main"
    class="mx-auto px-6 sm:px-10 pt-24 pb-24 min-h-[60vh]"
    style="max-width: var(--w-home)"
  >
    <p
      class="text-[11px] tracking-[0.12em] uppercase acc-blog font-mono"
    >
      <span class="acc-dot"></span>§ 404
    </p>
    <h1
      class="mt-4 font-serif text-[56px] sm:text-[80px] leading-[1.02] tracking-[-0.015em]"
      style="font-family: var(--font-serif)"
    >
      Introuvable.
    </h1>
    <p
      class="mt-6 text-[16px] text-[#2a2622] leading-relaxed max-w-[480px]"
    >
      Cette page n'existe pas ou a été déplacée. Tout ce qu'il y a à lire
      se trouve à deux clics d'ici.
    </p>
    <p class="mt-8 flex gap-5 text-[13px]">
      <a href="/" class="link-u text-[color:var(--color-ink)]">← Accueil</a>
      <span class="text-[color:var(--color-rule-strong)]">·</span>
      <a href="/blog" class="link-u acc-blog">Voir le blog</a>
    </p>
  </main>
</SiteLayout>
