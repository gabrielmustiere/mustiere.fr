---
import SiteLayout from '../../layouts/SiteLayout.astro';
import Footer from '../../components/layout/Footer.astro';
import CategoryPill from '../../components/ui/CategoryPill.astro';
import StructuredData from '../../components/seo/StructuredData.astro';
import { getCollection } from 'astro:content';
import {
  personSchema,
  blogSchema,
  breadcrumbSchema,
} from '../../utils/schema';
import {
  formatDateDotted,
  toISODate,
} from '../../utils/format-date';
import { SITE } from '../../consts';
import type { Category } from '../../content.config';

const all = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime()
);

const featured = all[0];
const archive = all.slice(1);
const totalCount = all.length;

const categories: Category[] = ['IA', 'Tech', 'Lead', 'Business'];

const description = `Blog de Gabriel Mustiere : ${totalCount} billets sur l'IA, la tech, le leadership et le business. Notes et essais d'un CTO freelance basé à Nantes.`;
---

<SiteLayout
  title="Écrits — Blog"
  description={description}
  type="website"
  current="blog"
>
  <StructuredData
    slot="head"
    schemas={[
      personSchema(),
      blogSchema(),
      breadcrumbSchema([
        { name: 'Accueil', url: SITE.url },
        { name: 'Écrits', url: `${SITE.url}/blog` },
      ]),
    ]}
  />

  <main
    id="main"
    class="mx-auto px-6 sm:px-10 pt-10 sm:pt-16 pb-20"
    style="max-width: var(--w-blog)"
  >
    <div
      class="flex items-center justify-between text-[11px] tracking-[0.12em] uppercase font-mono"
    >
      <span class="acc-blog"><span class="acc-dot"></span>§ 02 · Écrits</span>
      <span class="tnum text-[color:var(--color-muted)]"
        >{totalCount} billet{totalCount > 1 ? 's' : ''}</span
      >
    </div>

    <h1
      class="font-serif mt-6 text-[52px] sm:text-[72px] leading-[1.02] tracking-[-0.015em]"
      style="font-family: var(--font-serif)"
    >
      Écrits<br /><em class="acc-blog">au long cours.</em>
    </h1>

    <p
      class="mt-6 text-[15px] sm:text-[16px] text-[#2a2622] leading-[1.7] max-w-[560px]"
    >
      Notes et essais sur la <span class="acc-blog">tech</span>, le
      <span class="acc-about">business</span> et l'<span class="acc-projects"
        >IA</span
      >. Pas de fréquence — juste quand j'ai quelque chose à dire.
    </p>

    <div
      class="mt-10 flex flex-wrap items-center gap-2"
      id="filters"
      role="group"
      aria-label="Filtrer par catégorie"
    >
      <button
        type="button"
        data-tag="all"
        class="cat-pill text-[color:var(--color-ink)] chip-active"
        aria-pressed="true"
      >
        <span>Tout</span>
      </button>
      {
        categories.map((cat) => (
          <button
            type="button"
            data-tag={cat}
            class:list={[
              'cat-pill',
              {
                'acc-projects': cat === 'IA',
                'acc-blog': cat === 'Tech',
                'acc-about': cat === 'Lead',
                'acc-contact': cat === 'Business',
              },
            ]}
            aria-pressed="false"
          >
            <span>{cat}</span>
          </button>
        ))
      }
    </div>

    {
      featured && (
        <section class="mt-12 border-t border-[color:var(--color-rule-strong)] pt-6" data-tags={featured.data.category}>
          <div class="flex items-baseline justify-between text-[10px] tracking-[0.14em] uppercase text-[color:var(--color-muted)] font-mono">
            <span>À la une</span>
            <span class="tnum">№ {String(featured.data.number).padStart(2, '0')}</span>
          </div>
          <a href={`/blog/${featured.id}`} class="block mt-3 group">
            <h2
              class="font-serif text-[30px] sm:text-[42px] leading-[1.08] tracking-[-0.015em] group-hover:text-[color:var(--a-blog)] transition-colors"
              style="font-family: var(--font-serif)"
            >
              {featured.data.title}
            </h2>
          </a>
          <div class="mt-4 flex items-center gap-4 text-[11px] tracking-[0.1em] uppercase text-[color:var(--color-muted)] font-mono">
            <time class="tnum acc-blog" datetime={toISODate(featured.data.publishedAt)}>
              {formatDateDotted(featured.data.publishedAt)}
            </time>
            <span aria-hidden="true">·</span>
            <CategoryPill category={featured.data.category} size="sm" />
            {featured.data.readingTime && (
              <>
                <span aria-hidden="true">·</span>
                <span class="tnum">{featured.data.readingTime} min</span>
              </>
            )}
          </div>
          <p class="mt-4 text-[15px] text-[#2a2622] leading-[1.75] max-w-[560px]">
            {featured.data.excerpt}
          </p>
        </section>
      )
    }

    <section class="mt-16">
      <div
        class="text-[10px] tracking-[0.14em] uppercase text-[color:var(--color-muted)] mb-3 font-mono"
      >
        Archive
      </div>
      <ul id="archive">
        {
          archive.map((post) => (
            <li
              class="py-5 border-t border-[color:var(--color-rule)]"
              data-tags={post.data.category}
            >
              <a
                href={`/blog/${post.id}`}
                class="grid grid-cols-[80px_1fr] sm:grid-cols-[110px_1fr_80px_60px] gap-3 sm:gap-5 items-baseline group"
              >
                <time
                  class="tnum text-[11px] tracking-[0.08em] uppercase acc-blog font-mono"
                  datetime={toISODate(post.data.publishedAt)}
                >
                  {formatDateDotted(post.data.publishedAt)}
                </time>
                <h3
                  class="font-serif text-[19px] sm:text-[23px] leading-[1.25] tracking-[-0.005em] col-span-2 sm:col-span-1 group-hover:text-[color:var(--a-blog)] transition-colors"
                  style="font-family: var(--font-serif)"
                >
                  {post.data.title}
                </h3>
                <span class="hidden sm:inline">
                  <CategoryPill category={post.data.category} size="sm" />
                </span>
                {post.data.readingTime && (
                  <span class="hidden sm:inline text-[11px] tnum text-right text-[color:var(--color-muted)]">
                    {post.data.readingTime} min
                  </span>
                )}
              </a>
            </li>
          ))
        }
        <li class="border-t border-[color:var(--color-rule)]"></li>
      </ul>
      <p
        id="empty"
        class="hidden mt-6 text-[13px] text-[color:var(--color-muted)]"
        aria-live="polite"
      >
        Rien dans cette catégorie pour l'instant.
      </p>
    </section>
  </main>

  <Footer variant="blog" maxWidth="820px" />
</SiteLayout>

<style is:global>
  .cat-pill {
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    border: 1px solid currentColor;
    border-radius: 999px;
    padding: 2px 8px;
    cursor: pointer;
    font-family: var(--font-mono);
  }
  .chip-active {
    background: currentColor;
  }
  .chip-active > span {
    color: var(--color-bg);
  }
</style>

<script>
  const filters = document.getElementById('filters');
  const posts = document.querySelectorAll<HTMLLIElement>(
    '#archive li[data-tags]'
  );
  const empty = document.getElementById('empty');
  if (filters && empty) {
    filters.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      const btn = target.closest<HTMLButtonElement>('button[data-tag]');
      if (!btn) return;
      filters.querySelectorAll('button').forEach((x) => {
        x.classList.remove('chip-active');
        x.setAttribute('aria-pressed', 'false');
      });
      btn.classList.add('chip-active');
      btn.setAttribute('aria-pressed', 'true');

      const tag = btn.dataset.tag!;
      let shown = 0;
      posts.forEach((li) => {
        const tags = li.dataset.tags ?? '';
        const show = tag === 'all' || tags.includes(tag);
        li.classList.toggle('hidden', !show);
        if (show) shown++;
      });
      empty.classList.toggle('hidden', shown > 0);
    });
  }
</script>
