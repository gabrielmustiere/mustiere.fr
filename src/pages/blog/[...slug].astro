---
import { getCollection, type CollectionEntry } from 'astro:content';
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import { readingTimeFromText } from '../../utils/reading-time';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  const sorted = [...posts].sort(
    (a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime()
  );

  return posts.map((post) => {
    const idx = sorted.findIndex((p) => p.slug === post.slug);
    const nextPosts = [sorted[idx + 1], sorted[idx - 1]].filter(
      (p): p is CollectionEntry<'blog'> => Boolean(p)
    );
    return {
      params: { slug: post.slug },
      props: { post, nextPosts },
    };
  });
}

type Props = {
  post: CollectionEntry<'blog'>;
  nextPosts: CollectionEntry<'blog'>[];
};
const { post, nextPosts } = Astro.props as Props;

const { Content, remarkPluginFrontmatter } = await post.render();

if (!post.data.readingTime && post.body) {
  post.data.readingTime = readingTimeFromText(post.body);
}

void remarkPluginFrontmatter;
---

<ArticleLayout post={post} nextPosts={nextPosts}>
  <Content />
</ArticleLayout>
