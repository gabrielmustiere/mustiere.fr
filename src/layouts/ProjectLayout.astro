---
import SiteLayout from './SiteLayout.astro';
import Footer from '@components/layout/Footer.astro';
import ReadingProgress from '@components/ui/ReadingProgress.astro';
import StructuredData from '@components/seo/StructuredData.astro';
import Resume from '@components/ui/Resume.astro';
import SectionMarker from '@components/ui/SectionMarker.astro';
import AuthorCard from '@components/ui/AuthorCard.astro';
import RelatedItems from '@components/ui/RelatedItems.astro';
import Faq from '@components/ui/Faq.astro';
import Sources from '@components/ui/Sources.astro';
import TableOfContents from '@components/ui/TableOfContents.astro';
import {
  breadcrumbSchema,
  faqPageSchema,
  softwareSourceCodeSchema,
} from '@/utils/schema';
import { truncateForMeta } from '@/utils/meta';
import { SITE } from '@/consts';
import {
  useTranslations,
  localizedPath,
  otherLang as otherLangOf,
} from '@/i18n/utils';
import type { Lang } from '@/i18n/config';
import { getCollection, type CollectionEntry } from 'astro:content';
import { isPublished } from '@/utils/content';
import type { MarkdownHeading } from 'astro';

interface Props {
  project: CollectionEntry<'projects'>;
  others: CollectionEntry<'projects'>[];
  headings?: MarkdownHeading[];
}

const { project, others, headings = [] } = Astro.props;
const { data } = project;
const lang: Lang = (data.lang ?? 'fr') as Lang;
const tr = useTranslations(lang);

const url = new URL(localizedPath(lang, `/projects/${project.id}`), SITE.url)
  .href;
const homeHref = localizedPath(lang, '/');

const otherLangCode: Lang = otherLangOf(lang);
// `data.translationOf` n'est pas une garantie de publication : la traduction
// peut être en draft (donc absente du build prod). On ne pointe vers la page
// traduite que si elle passe `isPublished` dans le mode courant.
const translatedEntry = data.translationOf
  ? (
      await getCollection(
        'projects',
        (entry) =>
          entry.id === data.translationOf && isPublished(entry, otherLangCode)
      )
    )[0]
  : undefined;
const otherLangHref = translatedEntry
  ? localizedPath(otherLangCode, `/projects/${translatedEntry.id}`)
  : localizedPath(otherLangCode, '/');

const relatedUrls = others.map(
  (o) => new URL(localizedPath(lang, `/projects/${o.id}`), SITE.url).href
);

const schemas = [
  softwareSourceCodeSchema({
    title: data.title,
    description: data.excerpt,
    slug: project.id,
    year: data.year,
    repository: data.url,
    lang,
    cover: data.cover,
    abstract: data.resume.plain,
    relatedUrls,
  }),
  breadcrumbSchema([
    { name: tr.breadcrumb.home, url: `${SITE.url}${homeHref}` },
    { name: tr.home.projects.title, url: `${SITE.url}${homeHref}#projects` },
    { name: data.title, url },
  ]),
  ...(data.faq.length > 0 ? [faqPageSchema(data.faq)] : []),
];

const tocTitle = tr.project.tocTitle;
const endLabel = tr.project.endLabel;
const metaDescription = truncateForMeta(data.resume.plain);
---

<SiteLayout
  title={data.title}
  description={metaDescription}
  image={data.cover}
  type="article"
  current="project"
  lang={lang}
  otherLangHref={otherLangHref}
>
  <StructuredData slot="head" schemas={schemas} />

  <ReadingProgress />

  <main id="main">
    <article
      class="mx-auto px-6 sm:px-10 pt-10 sm:pt-16 pb-20"
      style="max-width: var(--w-prose)"
    >
      <nav
        class="text-[11px] tracking-[0.12em] uppercase text-[color:var(--color-muted)] flex items-center gap-2 font-mono"
        aria-label={tr.breadcrumb.ariaLabel}
      >
        <a
          href={`${homeHref}#projects`}
          class="hover:text-[color:var(--color-ink)]"
        >
          ← {tr.home.projects.title}
        </a>
        <span class="text-[color:var(--color-rule-strong)]" aria-hidden="true"
          >/</span
        >
        <span class="acc-projects">{data.kind}</span>
      </nav>

      <header class="mt-10">
        <div
          class="flex items-center gap-3 text-[11px] tracking-[0.12em] uppercase font-mono"
        >
          <span class="acc-projects tnum">{data.status}</span>
          <span class="text-[color:var(--color-rule-strong)]" aria-hidden="true"
            >·</span
          >
          <span class="acc-projects tnum">{data.year}</span>
          <span class="text-[color:var(--color-rule-strong)]" aria-hidden="true"
            >·</span
          >
          <span class="tnum text-[color:var(--color-muted)]">{data.kind}</span>
        </div>
        {
          data.cover && (
            <img
              src={data.cover}
              alt=""
              loading="eager"
              fetchpriority="high"
              decoding="async"
              class="mt-5 w-full aspect-[16/9] object-cover rounded-md"
              transition:name={`project-cover-${project.id}`}
            />
          )
        }
        <h1
          class="font-serif mt-5 text-[40px] sm:text-[60px] leading-[1.04] tracking-[-0.015em]"
          style="font-family: var(--font-serif)"
          transition:name={`project-title-${project.id}`}
        >
          {data.title}
        </h1>
        <p
          class="mt-6 text-[17px] sm:text-[19px] text-[#2a2622] leading-[1.55] font-serif"
          data-speakable
        >
          {data.subtitle}
        </p>

        <Resume
          html={data.resume.html}
          label={tr.project.summaryLabel}
          accent="projects"
          ariaLabel={tr.project.summaryAria}
        />

        <AuthorCard
          shareTitle={data.title}
          shareUrl={url}
          lang={lang}
          accent="projects"
        />

        {
          data.url && (
            <div class="mt-6">
              <a
                href={data.url}
                target="_blank"
                rel="noopener"
                class="inline-flex items-center gap-2 text-[12px] tracking-[0.1em] uppercase font-mono text-[color:var(--color-ink)] border border-[color:var(--color-ink)] rounded-full px-4 py-2 hover:bg-[color:var(--color-ink)] hover:text-[color:var(--color-bg)] transition-colors"
              >
                <svg
                  aria-hidden="true"
                  width="14"
                  height="14"
                  viewBox="0 0 16 16"
                  fill="currentColor"
                >
                  <path d="M8 0C3.58 0 0 3.58 0 8a8 8 0 005.47 7.59c.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82a7.42 7.42 0 014 0c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z" />
                </svg>
                <span>{tr.project.viewOnGitHub}</span>
                <span aria-hidden="true">↗</span>
              </a>
            </div>
          )
        }
      </header>

      <TableOfContents headings={headings} title={tocTitle} accent="projects" />

      <div class="prose mt-10">
        <slot />
      </div>

      {
        data.faq.length > 0 && (
          <Faq items={data.faq} title={tr.project.faqTitle} accent="projects" />
        )
      }

      {
        data.sources.length > 0 && (
          <Sources
            items={data.sources}
            title={tr.project.sourcesTitle}
            accent="projects"
          />
        )
      }

      <SectionMarker
        label={endLabel}
        accent="projects"
        trailing={String(data.year)}
      />

      <RelatedItems
        kind="project"
        title={tr.project.otherProjects}
        items={others}
        lang={lang}
      />
    </article>
  </main>

  <Footer variant="project" maxWidth="720px" lang={lang} />
</SiteLayout>
