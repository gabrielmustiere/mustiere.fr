---
import SiteLayout from './SiteLayout.astro';
import Footer from '@components/layout/Footer.astro';
import ReadingProgress from '@components/ui/ReadingProgress.astro';
import CategoryPill from '@components/ui/CategoryPill.astro';
import ArticleCard from '@components/ui/ArticleCard.astro';
import StructuredData from '@components/seo/StructuredData.astro';
import Resume from '@components/ui/Resume.astro';
import SectionMarker from '@components/ui/SectionMarker.astro';
import AuthorCard from '@components/ui/AuthorCard.astro';
import RelatedItems from '@components/ui/RelatedItems.astro';
import Faq from '@components/ui/Faq.astro';
import Sources from '@components/ui/Sources.astro';
import TableOfContents from '@components/ui/TableOfContents.astro';
import {
  blogPostingSchema,
  breadcrumbSchema,
  faqPageSchema,
} from '@/utils/schema';
import { formatDateDottedFull, toISODate } from '@/utils/format-date';
import { getOgImage } from '@/utils/article-cover';

import { truncateForMeta } from '@/utils/meta';
import { SITE } from '@/consts';
import {
  useTranslations,
  localizedPath,
  otherLang as otherLangOf,
} from '@/i18n/utils';
import type { Lang } from '@/i18n/config';
import { getCollection, type CollectionEntry } from 'astro:content';
import { isPublished } from '@/utils/content';
import type { MarkdownHeading } from 'astro';

interface Props {
  post: CollectionEntry<'blog'>;
  nextPosts: CollectionEntry<'blog'>[];
  headings?: MarkdownHeading[];
}

const { post, nextPosts, headings = [] } = Astro.props;
const { data } = post;
const lang: Lang = (data.lang ?? 'fr') as Lang;
const tr = useTranslations(lang);

const url = new URL(localizedPath(lang, `/blog/${post.id}`), SITE.url).href;
const blogHref = localizedPath(lang, '/blog');
const homeHref = localizedPath(lang, '/');

const otherLang: Lang = otherLangOf(lang);
// `data.translationOf` n'est pas une garantie de publication : la traduction
// peut être en draft (donc absente du build prod). On ne pointe vers la page
// traduite que si elle passe `isPublished` dans le mode courant.
const translatedPost = data.translationOf
  ? (
      await getCollection(
        'blog',
        (entry) =>
          entry.id === data.translationOf && isPublished(entry, otherLang)
      )
    )[0]
  : undefined;
const otherLangHref = translatedPost
  ? localizedPath(otherLang, `/blog/${translatedPost.id}`)
  : localizedPath(otherLang, '/blog');

const relatedUrls = nextPosts.map(
  (n) => new URL(localizedPath(lang, `/blog/${n.id}`), SITE.url).href
);

const ogImage = await getOgImage(post);

const schemas = [
  blogPostingSchema({
    title: data.title,
    description: data.excerpt,
    slug: post.id,
    publishedAt: data.publishedAt,
    updatedAt: data.updatedAt,
    category: data.category,
    keywords: data.keywords,
    readingTime: data.readingTime,
    image: ogImage.url,
    imageWidth: ogImage.width,
    imageHeight: ogImage.height,
    tldr: data.resume.plain,
    lang,
    relatedUrls,
  }),
  breadcrumbSchema([
    { name: tr.breadcrumb.home, url: `${SITE.url}${homeHref}` },
    { name: tr.home.blog.title, url: `${SITE.url}${blogHref}` },
    { name: data.title, url },
  ]),
  ...(data.faq.length > 0 ? [faqPageSchema(data.faq)] : []),
];

const tocTitle = tr.article.tocTitle;
const upNextTitle = tr.article.upNextTitle;
const endLabel = tr.article.endLabel;
const metaDescription = truncateForMeta(data.resume.plain);
---

<SiteLayout
  title={data.title}
  description={metaDescription}
  type="article"
  publishedTime={data.publishedAt}
  modifiedTime={data.updatedAt}
  category={data.category}
  tags={data.tags}
  image={ogImage.url}
  imageWidth={ogImage.width}
  imageHeight={ogImage.height}
  current="article"
  lang={lang}
  otherLangHref={otherLangHref}
>
  <StructuredData slot="head" schemas={schemas} />

  <ReadingProgress />

  <main id="main">
    <article
      class="mx-auto px-6 sm:px-10 pt-10 sm:pt-16 pb-20"
      style="max-width: var(--w-prose)"
    >
      <nav
        class="text-[11px] tracking-[0.12em] uppercase text-[color:var(--color-muted)] flex items-center gap-2 font-mono"
        aria-label={tr.breadcrumb.ariaLabel}
      >
        <a href={blogHref} class="hover:text-[color:var(--color-ink)]">
          ← {tr.home.blog.title}
        </a>
        <span class="text-[color:var(--color-rule-strong)]" aria-hidden="true"
          >/</span
        >
        <CategoryPill category={data.category} size="sm" lang={lang} />
      </nav>

      <ArticleCard entry={post} variant="lg" lang={lang} loading="eager" />

      <Resume
        html={data.resume.html}
        label={tr.article.summaryLabel}
        accent="blog"
        ariaLabel={tr.article.summaryAria}
      />

      <AuthorCard
        shareTitle={data.title}
        shareUrl={url}
        lang={lang}
        accent="blog"
      />

      <TableOfContents headings={headings} title={tocTitle} accent="blog" />

      <div class="prose mt-10">
        <slot />
      </div>

      {
        data.faq.length > 0 && (
          <Faq items={data.faq} title={tr.project.faqTitle} accent="blog" />
        )
      }

      {
        data.sources.length > 0 && (
          <Sources
            items={data.sources}
            title={tr.article.sourcesTitle}
            accent="blog"
          />
        )
      }

      {
        data.updatedAt &&
        data.updatedAt.getTime() !== data.publishedAt.getTime() ? (
          <SectionMarker label={endLabel} accent="blog">
            <Fragment slot="trailing">
              {tr.article.publishedOn}{' '}
              <time datetime={toISODate(data.publishedAt)}>
                {formatDateDottedFull(data.publishedAt)}
              </time>
              {' · '}
              {tr.article.updatedOn}{' '}
              <time datetime={toISODate(data.updatedAt)}>
                {formatDateDottedFull(data.updatedAt)}
              </time>
            </Fragment>
          </SectionMarker>
        ) : (
          <SectionMarker
            label={endLabel}
            accent="blog"
            trailing={formatDateDottedFull(data.publishedAt)}
            trailingDateTime={toISODate(data.publishedAt)}
          />
        )
      }

      <RelatedItems
        kind="blog"
        title={upNextTitle}
        items={nextPosts}
        lang={lang}
      />
    </article>
  </main>

  <Footer variant="article" maxWidth="720px" lang={lang} />
</SiteLayout>
