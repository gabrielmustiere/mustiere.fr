---
import SiteLayout from './SiteLayout.astro';
import Footer from '../components/layout/Footer.astro';
import ReadingProgress from '../components/ui/ReadingProgress.astro';
import CategoryPill from '../components/ui/CategoryPill.astro';
import StructuredData from '../components/seo/StructuredData.astro';
import Callout from '../components/ui/Callout.astro';
import SectionMarker from '../components/ui/SectionMarker.astro';
import AuthorCard from '../components/ui/AuthorCard.astro';
import RelatedItems from '../components/ui/RelatedItems.astro';
import Faq from '../components/ui/Faq.astro';
import TableOfContents from '../components/ui/TableOfContents.astro';
import {
  blogPostingSchema,
  breadcrumbSchema,
  faqPageSchema,
} from '../utils/schema';
import {
  formatDateDottedFull,
  toISODate,
} from '../utils/format-date';
import { SITE } from '../consts';
import { useTranslations, localizedPath } from '../i18n/utils';
import type { Lang } from '../i18n/config';
import type { CollectionEntry } from 'astro:content';
import type { MarkdownHeading } from 'astro';

interface Props {
  post: CollectionEntry<'blog'>;
  nextPosts: CollectionEntry<'blog'>[];
  headings?: MarkdownHeading[];
}

const { post, nextPosts, headings = [] } = Astro.props;
const { data } = post;
const lang: Lang = (data.lang ?? 'fr') as Lang;
const tr = useTranslations(lang);

const url = new URL(localizedPath(lang, `/blog/${post.id}`), SITE.url).href;
const blogHref = localizedPath(lang, '/blog');
const homeHref = localizedPath(lang, '/');

const otherLang: Lang = lang === 'fr' ? 'en' : 'fr';
const otherLangHref = data.translationOf
  ? localizedPath(otherLang, `/blog/${data.translationOf}`)
  : localizedPath(otherLang, '/blog');

const relatedUrls = nextPosts.map(
  (n) => new URL(localizedPath(lang, `/blog/${n.id}`), SITE.url).href
);

const schemas = [
  blogPostingSchema({
    title: data.title,
    description: data.excerpt,
    slug: post.id,
    publishedAt: data.publishedAt,
    updatedAt: data.updatedAt,
    category: data.category,
    keywords: data.keywords,
    readingTime: data.readingTime,
    image: data.ogImage,
    tldr: data.tldr,
    lang,
    relatedUrls,
  }),
  breadcrumbSchema([
    { name: lang === 'fr' ? 'Accueil' : 'Home', url: `${SITE.url}${homeHref}` },
    { name: tr.home.blog.title, url: `${SITE.url}${blogHref}` },
    { name: data.title, url },
  ]),
  ...(data.faq.length > 0 ? [faqPageSchema(data.faq)] : []),
];

const tocTitle = lang === 'fr' ? 'sommaire' : 'contents';
const upNextTitle = lang === 'fr' ? 'À lire ensuite' : 'Up next';
const endLabel = lang === 'fr' ? '§ fin' : '§ end';
---

<SiteLayout
  title={data.title}
  description={data.excerpt}
  type="article"
  publishedTime={data.publishedAt}
  modifiedTime={data.updatedAt}
  category={data.category}
  tags={data.tags}
  image={data.ogImage}
  current="article"
  lang={lang}
  otherLangHref={otherLangHref}
>
  <StructuredData slot="head" schemas={schemas} />

  <ReadingProgress />

  <main id="main">
    <article
      class="mx-auto px-6 sm:px-10 pt-10 sm:pt-16 pb-20"
      style="max-width: var(--w-prose)"
    >
      <nav
        class="text-[11px] tracking-[0.12em] uppercase text-[color:var(--color-muted)] flex items-center gap-2 font-mono"
        aria-label={lang === 'fr' ? "Fil d'Ariane" : 'Breadcrumb'}
      >
        <a href={blogHref} class="hover:text-[color:var(--color-ink)]">
          ← {tr.home.blog.title}
        </a>
        <span class="text-[color:var(--color-rule-strong)]" aria-hidden="true"
          >/</span
        >
        <CategoryPill category={data.category} size="sm" lang={lang} />
      </nav>

      <header class="mt-10">
        <div
          class="flex items-center gap-3 text-[11px] tracking-[0.12em] uppercase font-mono"
        >
          <span class="acc-blog tnum"
            >№ {String(data.number).padStart(2, '0')}</span
          >
          <span class="text-[color:var(--color-rule-strong)]" aria-hidden="true"
            >·</span
          >
          <time
            class="acc-blog tnum"
            datetime={toISODate(data.publishedAt)}
          >
            {formatDateDottedFull(data.publishedAt)}
          </time>
          {
            data.readingTime && (
              <>
                <span class="text-[color:var(--color-rule-strong)]" aria-hidden="true">·</span>
                <span class="tnum text-[color:var(--color-muted)]">{data.readingTime} min</span>
              </>
            )
          }
        </div>
        <h1
          class="font-serif mt-5 text-[40px] sm:text-[60px] leading-[1.04] tracking-[-0.015em]"
          style="font-family: var(--font-serif)"
        >
          {data.title}
        </h1>
        <p
          class="mt-6 text-[17px] sm:text-[19px] text-[#2a2622] leading-[1.55] font-serif"
          data-speakable
        >
          {data.excerpt}
        </p>

        {
          data.tldr && (
            <Callout
              label={tr.article.tldrLabel}
              accent="blog"
              ariaLabel={tr.article.tldrLabel}
            >
              <span data-speakable>{data.tldr}</span>
            </Callout>
          )
        }

        <AuthorCard
          shareTitle={data.title}
          shareUrl={url}
          lang={lang}
          accent="blog"
        />
      </header>

      <TableOfContents
        headings={headings}
        title={tocTitle}
        accent="blog"
      />

      <div class="prose mt-10">
        <slot />
      </div>

      {
        data.faq.length > 0 && (
          <Faq
            items={data.faq}
            title={tr.project.faqTitle}
            accent="blog"
          />
        )
      }

      <SectionMarker
        label={endLabel}
        accent="blog"
        trailing={formatDateDottedFull(data.updatedAt ?? data.publishedAt)}
        trailingDateTime={toISODate(data.updatedAt ?? data.publishedAt)}
      />

      <RelatedItems
        kind="blog"
        title={upNextTitle}
        items={nextPosts}
        lang={lang}
      />
    </article>
  </main>

  <Footer variant="article" maxWidth="720px" lang={lang} />
</SiteLayout>
