---
import '@fontsource/instrument-serif/400.css';
import '@fontsource/inter/300.css';
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/inter/600.css';
import '@fontsource/jetbrains-mono/400.css';
import '@fontsource/jetbrains-mono/500.css';

import '@styles/global.css';
import SkipLink from '@components/layout/SkipLink.astro';
import StructuredData from '@components/seo/StructuredData.astro';
import {
  organizationSchema,
  personSchema,
  websiteSchema,
} from '@/utils/schema';
import { SITE } from '@/consts';
import { getLangFromUrl, useTranslations, swapLang } from '@/i18n/utils';
import { LANG_META, type Lang } from '@/i18n/config';

export interface Props {
  lang?: Lang;
  title?: string;
  description?: string;
  image?: string;
  canonical?: string;
  type?: 'website' | 'article';
  publishedTime?: Date;
  modifiedTime?: Date;
  author?: string;
  category?: string;
  tags?: string[];
  noindex?: boolean;
  otherLangHref?: string;
}

const lang = Astro.props.lang ?? getLangFromUrl(Astro.url);
const tr = useTranslations(lang);

const {
  title,
  description = tr.site.description,
  image = SITE.ogImage,
  canonical,
  type = 'website',
  publishedTime,
  modifiedTime,
  author = SITE.author.name,
  category,
  tags = [],
  noindex = false,
  otherLangHref,
} = Astro.props;

const pageTitle = title ? `${title} — ${SITE.name}` : tr.site.title;

// Normalisation de l'URL canonique :
// - retire un éventuel suffixe .html hérité d'anciens builds
// - garantit un trailing slash pour les routes de page (cohérent avec trailingSlash: 'always')
// - conserve les URLs de fichiers (rss.xml, llms.txt…) telles quelles
function normalizeRoute(pathname: string): string {
  const stripped = pathname.replace(/\.html$/i, '');
  const isFile = /\.[a-z0-9]+$/i.test(stripped);
  if (isFile) return stripped;
  return stripped.endsWith('/') ? stripped : `${stripped}/`;
}

const normalizedPath = normalizeRoute(Astro.url.pathname);
const canonicalURL = canonical ?? new URL(normalizedPath, SITE.url).href;
const ogImageURL = new URL(image, SITE.url).href;
const otherLang: Lang = lang === 'fr' ? 'en' : 'fr';
const altPath = otherLangHref ?? swapLang(normalizedPath, otherLang);
const altUrl = new URL(altPath, SITE.url).href;
const rssHref = lang === 'fr' ? '/fr/rss.xml' : '/en/rss.xml';

const baseGraph = [organizationSchema(), websiteSchema(), personSchema(lang)];
---

<!doctype html>
<html lang={LANG_META[lang].htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="author" content={author} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="alternate" hreflang={otherLang} href={altUrl} />
    <link rel="alternate" hreflang={lang} href={canonicalURL} />
    <link
      rel="alternate"
      hreflang="x-default"
      href={lang === 'fr' ? canonicalURL : altUrl}
    />

    {
      noindex ? (
        <meta name="robots" content="noindex, nofollow" />
      ) : (
        <meta
          name="robots"
          content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1"
        />
      )
    }

    <meta property="og:type" content={type} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content={LANG_META[lang].ogLocale} />
    <meta
      property="og:locale:alternate"
      content={LANG_META[lang === 'fr' ? 'en' : 'fr'].ogLocale}
    />
    <meta property="og:site_name" content={SITE.name} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    {
      type === 'article' && publishedTime && (
        <meta
          property="article:published_time"
          content={publishedTime.toISOString()}
        />
      )
    }
    {
      type === 'article' && modifiedTime && (
        <meta
          property="article:modified_time"
          content={modifiedTime.toISOString()}
        />
      )
    }
    {
      type === 'article' && (
        <meta property="article:author" content={author} />
      )
    }
    {
      type === 'article' && category && (
        <meta property="article:section" content={category} />
      )
    }
    {
      type === 'article' &&
        tags.map((tag) => <meta property="article:tag" content={tag} />)
    }

    <meta name="theme-color" content="#fafaf7" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title={`${SITE.name} — ${tr.home.blog.title}`}
      href={rssHref}
    />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <StructuredData schemas={baseGraph} />

    <slot name="head" />
  </head>
  <body>
    <SkipLink lang={lang} />
    <slot />
  </body>
</html>
