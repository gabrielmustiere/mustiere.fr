---
import BaseLayout from './BaseLayout.astro';
import Sidebar, { type SidebarMode } from '@components/layout/Sidebar.astro';
import MobileNav from '@components/layout/MobileNav.astro';
import { getLangFromUrl } from '@/i18n/utils';
import type { Lang } from '@/i18n/config';

interface Props {
  lang?: Lang;
  title?: string;
  description?: string;
  image?: string;
  imageWidth?: number;
  imageHeight?: number;
  canonical?: string;
  type?: 'website' | 'article';
  publishedTime?: Date;
  modifiedTime?: Date;
  author?: string;
  category?: string;
  tags?: string[];
  noindex?: boolean;
  current?: SidebarMode;
  otherLangHref?: string;
}

const lang = Astro.props.lang ?? getLangFromUrl(Astro.url);
const { current = 'home', otherLangHref, ...baseProps } = Astro.props;
---

<BaseLayout {...baseProps} lang={lang} otherLangHref={otherLangHref}>
  <slot name="head" slot="head" />

  <MobileNav current={current} lang={lang} otherLangHref={otherLangHref} />

  <div class="layout">
    <Sidebar current={current} lang={lang} otherLangHref={otherLangHref} />
    <div class="main-col" id="top">
      <slot />
    </div>
  </div>
</BaseLayout>

<style is:global>
  .layout {
    display: block;
  }
  @media (min-width: 1024px) {
    .layout {
      display: grid;
      grid-template-columns: 260px 1fr;
      min-height: 100vh;
    }
  }
  .main-col {
    min-width: 0;
  }
  @media (min-width: 1024px) {
    .main-col {
      padding: 40px 64px;
    }
  }
  section[id],
  h2[id] {
    scroll-margin-top: calc(var(--mobile-nav-h, 0px) + 24px);
  }
</style>
