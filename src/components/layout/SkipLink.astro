---
import { getLangFromUrl } from '../../i18n/utils';
import type { Lang } from '../../i18n/config';

interface Props {
  href?: string;
  label?: string;
  lang?: Lang;
}

const lang = Astro.props.lang ?? getLangFromUrl(Astro.url);
const defaultLabel = lang === 'fr' ? 'Aller au contenu principal' : 'Skip to main content';
const { href = '#main', label = defaultLabel } = Astro.props;
---

<a href={href} class="skip-link">{label}</a>
