---
import { SITE } from '../../consts';
import { getLangFromUrl, useTranslations, localizedPath } from '../../i18n/utils';
import type { Lang } from '../../i18n/config';
import LangToggle from './LangToggle.astro';

export type SidebarMode = 'home' | 'blog' | 'article' | 'project';

interface Props {
  current?: SidebarMode;
  lang?: Lang;
  otherLangHref?: string;
}

const lang = Astro.props.lang ?? getLangFromUrl(Astro.url);
const tr = useTranslations(lang);
const { current = 'home', otherLangHref } = Astro.props;

const isHome = current === 'home';
const blogPath = localizedPath(lang, '/blog');
const homePath = localizedPath(lang, '/');

const index = [
  { key: 'blog', num: '01', label: tr.nav.items.blog, home: '#blog', away: blogPath },
  { key: 'about', num: '02', label: tr.nav.items.about, home: '#about', away: `${homePath}#about` },
  { key: 'projects', num: '03', label: tr.nav.items.projects, home: '#projects', away: `${homePath}#projects` },
  { key: 'contact', num: '04', label: tr.nav.items.contact, home: '#contact', away: `${homePath}#contact` },
  { key: 'cv', num: '05', label: tr.nav.items.cv, home: '#cv', away: `${homePath}#cv` },
] as const;

const activeKey =
  current === 'blog' || current === 'article'
    ? 'blog'
    : current === 'project'
      ? 'projects'
      : null;

const brandHref = isHome ? '#top' : homePath;
---

<aside class="sidebar" aria-label={tr.nav.ariaSidebar}>
  <a href={brandHref} class="avatar-link" aria-label={tr.nav.ariaBackHome}>
    <img
      src="/avatar.jpeg"
      alt={tr.portrait}
      width="56"
      height="56"
      class="avatar"
      loading="eager"
      decoding="async"
    />
  </a>
  <div
    class="mt-4 text-[11px] tracking-[0.12em] uppercase text-[color:var(--color-muted)]"
  >
    {SITE.name}
  </div>
  <a
    href={brandHref}
    class="font-serif mt-2 text-[34px] leading-[1.05] tracking-[-0.01em] block"
    style="font-family: var(--font-serif)"
  >
    {tr.site.role}<br /><em class="acc-about">{tr.site.roleSuffix}</em>
  </a>
  <p
    class="mt-4 text-[12.5px] text-[color:var(--color-muted)] leading-[1.55]"
  >
    {tr.site.tagline}<br />{tr.site.taglineLocation}
  </p>

  <nav class="mt-10" aria-label={tr.nav.ariaSections}>
    <div
      class="text-[10px] tracking-[0.14em] uppercase mb-2 text-[color:var(--color-muted)]"
    >
      {tr.nav.index}
    </div>
    <ul>
      {
        index.map(({ key, num, label, home, away }) => {
          const href = isHome ? home : away;
          const isActive = !isHome && activeKey === key;
          return (
            <li>
              <a
                href={href}
                class:list={['idx-link', { 'is-active': isActive }]}
                data-key={key}
                data-idx-link={isHome ? '' : undefined}
                aria-current={isActive ? 'page' : undefined}
              >
                <span class="num">{num}</span>
                <span class="label">{label}</span>
              </a>
            </li>
          );
        })
      }
    </ul>
  </nav>

  <div
    class="mt-auto text-[10px] tracking-[0.12em] uppercase text-[color:var(--color-muted)]"
  >
    <LangToggle variant="sidebar" lang={lang} otherLangHref={otherLangHref} />
    <div class="flex items-center gap-3 mb-3">
      <a
        href={SITE.author.github}
        target="_blank"
        rel="noopener"
        class="hover:text-[color:var(--color-ink)]">GitHub</a
      >
      <span class="text-[color:var(--color-rule-strong)]" aria-hidden="true">·</span>
      <a
        href={SITE.author.linkedin}
        target="_blank"
        rel="noopener"
        class="hover:text-[color:var(--color-ink)]">LinkedIn</a
      >
    </div>
    <div class="flex items-center gap-2 mb-1">
      <span
        class="inline-block w-[6px] h-[6px] rounded-full bg-[#5a7a4a]"
        aria-hidden="true"></span>
      <span>{tr.availability}</span>
    </div>
    <div>{tr.version}</div>
  </div>
</aside>

<style>
  .sidebar {
    display: none;
  }
  @media (min-width: 1024px) {
    .sidebar {
      display: flex;
      flex-direction: column;
      border-right: 1px solid var(--color-rule-strong);
      padding: 64px 32px 40px;
      position: sticky;
      top: 0;
      height: 100vh;
    }
  }
  .avatar-link {
    display: inline-block;
    line-height: 0;
    border-radius: 999px;
    transition: transform 0.2s ease;
  }
  .avatar-link:hover {
    transform: scale(1.03);
  }
  .avatar {
    width: 56px;
    height: 56px;
    border-radius: 999px;
    object-fit: cover;
    border: 1px solid var(--color-rule-strong);
    display: block;
  }
  .idx-link {
    display: grid;
    grid-template-columns: 22px 1fr;
    align-items: baseline;
    padding: 7px 0;
    font-size: 13px;
    color: #2a2622;
    transition: color 0.15s ease;
  }
  .idx-link .num {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.08em;
    color: var(--color-muted);
  }
  .idx-link:hover,
  .idx-link.is-active {
    color: var(--color-ink);
  }
  .idx-link .label::before {
    content: '';
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 999px;
    background: currentColor;
    margin-right: 8px;
    vertical-align: 2px;
    opacity: 0;
    transition: opacity 0.15s ease;
  }
  .idx-link.is-active .label::before {
    opacity: 1;
  }
  .idx-link[data-key='about'].is-active {
    color: var(--a-about);
  }
  .idx-link[data-key='blog'].is-active {
    color: var(--a-blog);
  }
  .idx-link[data-key='projects'].is-active {
    color: var(--a-projects);
  }
  .idx-link[data-key='contact'].is-active {
    color: var(--a-contact);
  }
  .idx-link[data-key='cv'].is-active {
    color: var(--a-cv);
  }
</style>

{
  isHome && (
    <script>
      const links = document.querySelectorAll<HTMLAnchorElement>(
        '[data-idx-link]'
      );
      if (links.length) {
        const byKey = new Map<string, HTMLAnchorElement>();
        links.forEach((a) => byKey.set(a.dataset.key!, a));

        const keys = ['blog', 'about', 'projects', 'contact', 'cv'];
        const sections = keys
          .map((k) => document.getElementById(k))
          .filter((el): el is HTMLElement => !!el);

        if (sections.length) {
          let current: string | null = null;
          const setActive = (key: string | null) => {
            if (key === current) return;
            current = key;
            links.forEach((a) => {
              const active = a.dataset.key === key;
              a.classList.toggle('is-active', active);
              if (active) {
                a.setAttribute('aria-current', 'location');
              } else {
                a.removeAttribute('aria-current');
              }
            });
          };

          const visibleIds = new Set<string>();
          const io = new IntersectionObserver(
            (entries) => {
              for (const e of entries) {
                if (e.isIntersecting) visibleIds.add(e.target.id);
                else visibleIds.delete(e.target.id);
              }
              const firstVisible = keys.find((k) => visibleIds.has(k));
              if (firstVisible) setActive(firstVisible);
            },
            {
              rootMargin: '-20% 0px -60% 0px',
              threshold: 0,
            }
          );

          sections.forEach((s) => io.observe(s));
        }
      }
    </script>
  )
}
