---
import { getLangFromUrl, swapLang } from '@/i18n/utils';
import { LANGUAGES, type Lang } from '@/i18n/config';
import { useTranslations } from '@/i18n/utils';

interface Props {
  variant?: 'sidebar' | 'mobile';
  lang?: Lang;
  /**
   * Optional override for the URL of the other-language version.
   * Useful when the target slug differs (translated slugs).
   */
  otherLangHref?: string;
}

const { variant = 'sidebar', otherLangHref } = Astro.props;
const lang = Astro.props.lang ?? getLangFromUrl(Astro.url);
const tr = useTranslations(lang);
const currentHref = Astro.url.pathname;
const ukClipId = `lang-toggle-uk-clip-${variant}`;

const hrefFor = (code: Lang): string => {
  if (code === lang) return currentHref;
  return otherLangHref ?? swapLang(Astro.url.pathname, code);
};
---

<div
  class:list={['lang-toggle', `lang-toggle--${variant}`]}
  role="group"
  aria-label={tr.toggle.ariaLabel}
>
  {
    LANGUAGES.map((code) => {
      const isActive = code === lang;
      const href = hrefFor(code);
      return (
        <a
          href={href}
          class:list={['lang-toggle__item', { 'is-active': isActive }]}
          hreflang={code}
          lang={code}
          aria-current={isActive ? 'true' : undefined}
          aria-label={
            code === 'fr' ? tr.toggle.switchToFrench : tr.toggle.switchToEnglish
          }
          data-lang={code}
        >
          <span class="lang-toggle__flag" aria-hidden="true">
            {code === 'fr' ? (
              <svg
                width="18"
                height="12"
                viewBox="0 0 3 2"
                xmlns="http://www.w3.org/2000/svg"
                preserveAspectRatio="none"
              >
                <rect width="1" height="2" fill="#002654" />
                <rect x="1" width="1" height="2" fill="#ffffff" />
                <rect x="2" width="1" height="2" fill="#ce1126" />
              </svg>
            ) : (
              <svg
                width="18"
                height="12"
                viewBox="0 0 60 30"
                xmlns="http://www.w3.org/2000/svg"
                preserveAspectRatio="none"
              >
                <clipPath id={ukClipId}>
                  <path d="M30,15 h30 v15 z v-15 h-30 z h-30 v15 z v-15 h30 z" />
                </clipPath>
                <rect width="60" height="30" fill="#012169" />
                <path
                  d="M0,0 L60,30 M60,0 L0,30"
                  stroke="#ffffff"
                  stroke-width="6"
                />
                <path
                  d="M0,0 L60,30 M60,0 L0,30"
                  clip-path={`url(#${ukClipId})`}
                  stroke="#c8102e"
                  stroke-width="4"
                />
                <path
                  d="M30,0 v30 M0,15 h60"
                  stroke="#ffffff"
                  stroke-width="10"
                />
                <path
                  d="M30,0 v30 M0,15 h60"
                  stroke="#c8102e"
                  stroke-width="6"
                />
              </svg>
            )}
          </span>
          <span class="lang-toggle__code">{code.toUpperCase()}</span>
        </a>
      );
    })
  }
</div>

<style>
  .lang-toggle {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }
  .lang-toggle__item {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--color-muted);
    text-decoration: none;
    padding: 2px 0;
    transition: color 0.15s ease;
    position: relative;
  }
  .lang-toggle__item:not(.is-active):hover {
    color: var(--color-ink);
  }
  .lang-toggle__item.is-active {
    color: var(--a-blog);
  }
  .lang-toggle__flag {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 18px;
    height: 12px;
    border-radius: 1px;
    overflow: hidden;
    box-shadow: 0 0 0 1px rgba(0, 0, 0, 0.12);
    transition:
      opacity 0.15s ease,
      filter 0.15s ease;
  }
  .lang-toggle__flag > svg {
    width: 100%;
    height: 100%;
    display: block;
  }
  .lang-toggle__item:not(.is-active) .lang-toggle__flag {
    opacity: 0.65;
    filter: saturate(0.85);
  }
  .lang-toggle__item:not(.is-active):hover .lang-toggle__flag {
    opacity: 1;
    filter: saturate(1);
  }
  .lang-toggle__code {
    font-feature-settings: 'tnum' 1;
  }
  .lang-toggle--sidebar {
    margin-bottom: 12px;
  }
  .lang-toggle--mobile {
    padding: 16px 0 4px;
  }
</style>

<script>
  // Preserve hash when swapping language
  function init() {
    document
      .querySelectorAll<HTMLAnchorElement>('.lang-toggle__item')
      .forEach((a) => {
        a.addEventListener('click', (e) => {
          if (a.getAttribute('aria-current') === 'true') {
            e.preventDefault();
            return;
          }
          const hash = window.location.hash;
          if (hash) {
            e.preventDefault();
            const base = a.getAttribute('href') ?? '';
            window.location.href = base + hash;
          }
        });
      });
  }

  document.addEventListener('astro:page-load', init);
</script>
