---
import { Picture } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import type { Lang } from '@/i18n/config';
import CategoryPill from './CategoryPill.astro';
import { localizedPath } from '@/i18n/utils';
import {
  formatDateShort,
  formatDateDottedFull,
  toISODate,
} from '@/utils/format-date';
import { getCover } from '@/utils/article-cover';

interface Props {
  entry: CollectionEntry<'blog'>;
  variant: 'lg' | 'md' | 'sm';
  lang: Lang;
  loading?: 'eager' | 'lazy';
  fetchpriority?: 'high' | 'auto';
  showCover?: boolean;
  headingLevel?: 2 | 3;
}

const {
  entry,
  variant,
  lang,
  loading = 'lazy',
  fetchpriority,
  showCover = true,
  headingLevel = 3,
} = Astro.props;
const SmHeading = `h${headingLevel}` as 'h2' | 'h3';
const { data } = entry;
const { cover, alt } = await getCover(entry);
const href = localizedPath(lang, `/blog/${entry.id}`);

// Toutes les variantes affichent désormais la cover full-width 16/9 au-dessus
// du titre. Les `widths` couvrent l'éventail de largeurs de rendu effectives
// par variante (lg/md = pleine prose ~720px, sm = grille 2 cols ~360px).
const sizes = { lg: 720, md: 720, sm: 480 } as const;
const size = sizes[variant];
const widths =
  variant === 'sm' ? [360, 480, 720, 960] : [480, 720, 1080, 1440];
const sizesAttr =
  variant === 'sm'
    ? '(min-width: 760px) 360px, 100vw'
    : '(min-width: 760px) 720px, 100vw';
// Toutes variantes : le titre est rendu en h1/h2/h3 immédiatement à côté
// de la <Picture>. Sans coverAlt explicite (cf. getCover), l'image est
// traitée comme décorative (`alt=""`) — sinon les lecteurs d'écran
// annoncent deux fois le libellé. Si l'auteur déclare un coverAlt qui
// décrit vraiment l'image (et pas le titre), on l'utilise comme alt.
const pictureAlt = alt;
---

{
  variant === 'lg' && (
    <header class="article-card article-card--lg">
      <div class="article-card__body">
        <div class="flex items-center gap-3 text-[11px] tracking-[0.12em] uppercase font-mono">
          <span class="acc-blog tnum">
            № {String(data.number).padStart(2, '0')}
          </span>
          <span
            class="text-[color:var(--color-rule-strong)]"
            aria-hidden="true"
          >
            ·
          </span>
          <time class="acc-blog tnum" datetime={toISODate(data.publishedAt)}>
            {formatDateDottedFull(data.publishedAt)}
          </time>
          {data.readingTime && (
            <>
              <span
                class="text-[color:var(--color-rule-strong)]"
                aria-hidden="true"
              >
                ·
              </span>
              <span class="tnum text-[color:var(--color-muted)]">
                {data.readingTime} min
              </span>
            </>
          )}
        </div>
        {showCover && (
          <Picture
            src={cover}
            formats={['avif', 'webp']}
            widths={widths}
            width={size}
            height={Math.round((size * 9) / 16)}
            alt={pictureAlt}
            loading={loading}
            fetchpriority={fetchpriority}
            sizes={sizesAttr}
            class="article-card__cover article-card__cover--lg mt-5"
          />
        )}
        <h1
          class="font-serif mt-5 text-[34px] sm:text-[48px] leading-[1.06] tracking-[-0.015em]"
          style="font-family: var(--font-serif)"
        >
          {data.title}
        </h1>
        <p
          class="mt-5 text-[17px] sm:text-[19px] text-[#2a2622] leading-[1.55] font-serif"
          data-speakable
        >
          {data.excerpt}
        </p>
      </div>
    </header>
  )
}

{
  variant === 'md' && (
    <a href={href} class="block group">
      <div class="article-card article-card--md">
        {showCover && (
          <Picture
            src={cover}
            formats={['avif', 'webp']}
            widths={widths}
            width={size}
            height={Math.round((size * 9) / 16)}
            alt={pictureAlt}
            loading={loading}
            fetchpriority={fetchpriority}
            sizes={sizesAttr}
            class="article-card__cover article-card__cover--md"
          />
        )}
        <div class="article-card__body">
          <h2
            class="font-serif text-[26px] sm:text-[36px] leading-[1.1] tracking-[-0.015em] group-hover:text-[color:var(--a-blog)] transition-colors"
            style="font-family: var(--font-serif)"
          >
            {data.title}
          </h2>
          <div class="mt-3 flex items-center gap-3 text-[11px] tracking-[0.1em] uppercase text-[color:var(--color-muted)] font-mono">
            <time class="tnum acc-blog" datetime={toISODate(data.publishedAt)}>
              {formatDateDottedFull(data.publishedAt)}
            </time>
            <span aria-hidden="true">·</span>
            <CategoryPill category={data.category} size="sm" lang={lang} />
            {data.readingTime && (
              <>
                <span aria-hidden="true">·</span>
                <span class="tnum">
                  {data.readingTime} min
                </span>
              </>
            )}
          </div>
          <p class="mt-3 text-[15px] text-[#2a2622] leading-[1.7] max-w-[560px]">
            {data.excerpt}
          </p>
        </div>
      </div>
    </a>
  )
}

{
  variant === 'sm' && (
    <a href={href} class="block group">
      <div class="article-card article-card--sm">
        {showCover && (
          <Picture
            src={cover}
            formats={['avif', 'webp']}
            widths={widths}
            width={size}
            height={Math.round((size * 9) / 16)}
            alt={pictureAlt}
            loading={loading}
            fetchpriority={fetchpriority}
            sizes={sizesAttr}
            class="article-card__cover article-card__cover--sm"
          />
        )}
        <div class="article-card__body">
          <SmHeading
            class="font-serif text-[19px] sm:text-[22px] leading-[1.25] tracking-[-0.005em] group-hover:text-[color:var(--a-blog)] transition-colors"
            style="font-family: var(--font-serif)"
          >
            {data.title}
          </SmHeading>
          <div class="mt-2 flex items-center gap-2 text-[10px] tracking-[0.14em] uppercase text-[color:var(--color-muted)] font-mono">
            <time class="tnum acc-blog" datetime={toISODate(data.publishedAt)}>
              {formatDateShort(data.publishedAt, lang)}
            </time>
            <span aria-hidden="true">·</span>
            <CategoryPill category={data.category} size="sm" lang={lang} />
            {data.readingTime && (
              <>
                <span aria-hidden="true">·</span>
                <span class="tnum">
                  {data.readingTime} min
                </span>
              </>
            )}
          </div>
        </div>
      </div>
    </a>
  )
}

<style>
  .article-card {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: 1rem;
  }
  .article-card--lg {
    gap: 1.75rem;
  }
  .article-card--sm {
    gap: 0.75rem;
  }
  .article-card__body {
    min-width: 0;
  }
  .article-card__cover {
    border-radius: 6px;
    overflow: hidden;
    object-fit: cover;
    width: 100%;
    height: auto;
    aspect-ratio: 16 / 9;
  }
</style>
