<div class="progress" aria-hidden="true">
  <div id="progress-bar"></div>
</div>

<style>
  .progress {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: transparent;
    z-index: 40;
    pointer-events: none;
  }
  .progress > div {
    height: 100%;
    width: 0%;
    background: var(--a-blog);
    transition: width 0.1s linear;
  }
  @media (prefers-reduced-motion: reduce) {
    .progress > div {
      transition: none;
    }
  }
</style>

<script>
  // Listeners portés sur `window` : les attacher à chaque page-load
  // dupliquerait. On garde une référence module-scope pour pouvoir
  // détacher/rebrancher proprement à chaque transition.
  let currentBar: HTMLElement | null = null;
  let currentUpdate: (() => void) | null = null;

  function init() {
    if (currentUpdate) {
      window.removeEventListener('scroll', currentUpdate);
      window.removeEventListener('resize', currentUpdate);
    }
    currentBar = document.getElementById('progress-bar');
    if (!currentBar) {
      currentUpdate = null;
      return;
    }
    const bar = currentBar;
    currentUpdate = () => {
      const h = document.documentElement;
      const scrolled = h.scrollTop;
      const max = h.scrollHeight - h.clientHeight;
      const pct = max > 0 ? (scrolled / max) * 100 : 0;
      bar.style.width = `${pct}%`;
    };
    currentUpdate();
    window.addEventListener('scroll', currentUpdate, { passive: true });
    window.addEventListener('resize', currentUpdate, { passive: true });
  }

  document.addEventListener('astro:page-load', init);
</script>
