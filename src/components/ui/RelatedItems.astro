---
import CategoryPill from './CategoryPill.astro';
import { localizedPath } from '@/i18n/utils';
import type { Lang } from '@/i18n/config';
import type { CollectionEntry } from 'astro:content';

type Props =
  | {
      kind: 'blog';
      title: string;
      items: CollectionEntry<'blog'>[];
      lang: Lang;
    }
  | {
      kind: 'project';
      title: string;
      items: CollectionEntry<'projects'>[];
      lang: Lang;
    };

const { kind, title, items, lang } = Astro.props;
const accent = kind === 'blog' ? 'var(--a-blog)' : 'var(--a-projects)';
const accentClass = kind === 'blog' ? 'acc-blog' : 'acc-projects';
const basePath = kind === 'blog' ? '/blog/' : '/projects/';
---

{
  items.length > 0 && (
    <aside class="mt-16" aria-label={title}>
      <div class="text-[10px] tracking-[0.14em] uppercase text-[color:var(--color-muted)] mb-4 font-mono">
        {title}
      </div>
      <ul class="grid grid-cols-1 sm:grid-cols-2 gap-6 list-none p-0 m-0">
        {items.map((item) => (
          <li>
            <a
              href={localizedPath(lang, `${basePath}${item.id}`)}
              class="block border-t border-[color:var(--color-rule)] pt-4 group"
              style={`--related-accent: ${accent}`}
            >
              <div class="flex items-center gap-2 text-[10px] tracking-[0.14em] uppercase font-mono">
                {kind === 'blog' ? (
                  <>
                    <CategoryPill
                      category={(item as CollectionEntry<'blog'>).data.category}
                      size="sm"
                      lang={lang}
                    />
                    <span
                      class="text-[color:var(--color-rule-strong)]"
                      aria-hidden="true"
                    >
                      ·
                    </span>
                    {(item as CollectionEntry<'blog'>).data.readingTime && (
                      <span class="tnum text-[color:var(--color-muted)]">
                        {(item as CollectionEntry<'blog'>).data.readingTime} min
                      </span>
                    )}
                  </>
                ) : (
                  <>
                    <span class={accentClass}>
                      {(item as CollectionEntry<'projects'>).data.status}
                    </span>
                    <span
                      class="text-[color:var(--color-rule-strong)]"
                      aria-hidden="true"
                    >
                      ·
                    </span>
                    <span class="tnum text-[color:var(--color-muted)]">
                      {(item as CollectionEntry<'projects'>).data.year}
                    </span>
                  </>
                )}
              </div>
              <h3
                class="font-serif mt-2 text-[22px] leading-[1.2] tracking-[-0.005em] transition-colors group-hover:text-[color:var(--related-accent)]"
                style="font-family: var(--font-serif)"
              >
                {item.data.title}
              </h3>
            </a>
          </li>
        ))}
      </ul>
    </aside>
  )
}
