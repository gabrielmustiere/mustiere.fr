---
import { getLangFromUrl, useTranslations } from '@/i18n/utils';
import type { Lang } from '@/i18n/config';

interface Props {
  title: string;
  url: string;
  lang?: Lang;
}

const { title, url } = Astro.props;
const lang = Astro.props.lang ?? getLangFromUrl(Astro.url);
const tr = useTranslations(lang);
---

<button
  type="button"
  class="share-btn ml-auto text-[11px] tracking-[0.14em] uppercase border border-[color:var(--color-rule-strong)] rounded-full px-3 py-1 hover:bg-white transition font-mono"
  data-share-title={title}
  data-share-url={url}
  data-share-copied={tr.article.shareCopied}
  aria-label={`${tr.article.share}: ${title}`}
>
  <span data-share-label>{tr.article.share}</span>
</button>

<script>
  document.querySelectorAll<HTMLButtonElement>('.share-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const title = btn.dataset.shareTitle ?? '';
      const url = btn.dataset.shareUrl ?? window.location.href;
      const copiedLabel = btn.dataset.shareCopied ?? 'Copied';
      const label = btn.querySelector<HTMLElement>('[data-share-label]');
      if (navigator.share) {
        try {
          await navigator.share({ title, url });
        } catch {
          /* user cancelled */
        }
        return;
      }
      try {
        await navigator.clipboard.writeText(url);
        if (label) {
          const prev = label.textContent;
          label.textContent = copiedLabel;
          setTimeout(() => {
            label.textContent = prev;
          }, 2000);
        }
      } catch {
        /* clipboard denied; noop */
      }
    });
  });
</script>
