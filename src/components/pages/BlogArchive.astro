---
import SiteLayout from '@layouts/SiteLayout.astro';
import Footer from '@components/layout/Footer.astro';
import CategoryPill from '@components/ui/CategoryPill.astro';
import StructuredData from '@components/seo/StructuredData.astro';
import HeroFR from '@components/i18n/blog-archive/hero/fr.astro';
import HeroEN from '@components/i18n/blog-archive/hero/en.astro';
import IntroFR from '@components/i18n/blog-archive/intro/fr.astro';
import IntroEN from '@components/i18n/blog-archive/intro/en.astro';
import { getCollection } from 'astro:content';
import { blogSchema, breadcrumbSchema } from '@/utils/schema';
import { formatDateDotted, toISODate } from '@/utils/format-date';
import { SITE } from '@/consts';
import type { Category } from '@/content.config';
import { useTranslations, localizedPath } from '@/i18n/utils';
import { BLOG_CATEGORIES } from '@/i18n/ui';
import type { Lang } from '@/i18n/config';
import { isPublished } from '@/utils/content';
import type { AstroComponentFactory } from 'astro/runtime/server/index.js';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const tr = useTranslations(lang);
const blogHref = localizedPath(lang, '/blog');
const homeHref = localizedPath(lang, '/');

const all = (
  await getCollection('blog', (entry) => isPublished(entry, lang))
).sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());

const featured = all[0];
const archive = all.slice(1);
const totalCount = all.length;

const categories: Category[] = ['IA', 'Tech', 'Lead', 'Business'];

const countLabel =
  totalCount === 0
    ? tr.blogIndex.countZero
    : totalCount === 1
      ? tr.blogIndex.countSingular
      : tr.blogIndex.countPlural.replace('{n}', String(totalCount));

const description = tr.blogIndex.metaDescription.replace('{count}', countLabel);

const countSuffix =
  totalCount > 1
    ? tr.blogIndex.countSuffixPlural
    : tr.blogIndex.countSuffixSingular;

const HERO: Record<Lang, AstroComponentFactory> = { fr: HeroFR, en: HeroEN };
const INTRO: Record<Lang, AstroComponentFactory> = { fr: IntroFR, en: IntroEN };
const Hero = HERO[lang];
const Intro = INTRO[lang];
---

<SiteLayout
  title={tr.blogIndex.heading}
  description={description}
  type="website"
  current="blog"
  lang={lang}
>
  <StructuredData
    slot="head"
    schemas={[
      blogSchema(lang),
      breadcrumbSchema([
        {
          name: tr.breadcrumb.home,
          url: `${SITE.url}${homeHref}`,
        },
        { name: tr.home.blog.title, url: `${SITE.url}${blogHref}` },
      ]),
    ]}
  />

  <main
    id="main"
    class="mx-auto px-6 sm:px-10 pt-10 sm:pt-16 pb-20"
    style="max-width: var(--w-blog)"
  >
    <div
      class="flex items-center justify-between text-[11px] tracking-[0.12em] uppercase font-mono"
    >
      <span class="acc-blog"
        ><span class="acc-dot"></span>§ 02 · {tr.home.blog.title}</span
      >
      <span class="tnum text-[color:var(--color-muted)]">
        {totalCount}
        {countSuffix}
      </span>
    </div>

    <Hero />

    <Intro />

    <div
      class="mt-10 flex flex-wrap items-center gap-2"
      id="filters"
      role="group"
      aria-label={tr.blogIndex.filterLabel}
    >
      <button
        type="button"
        data-tag="all"
        class="cat-pill text-[color:var(--color-ink)] chip-active"
        aria-pressed="true"
      >
        <span>{tr.blogIndex.allCategories}</span>
      </button>
      {
        categories.map((cat) => (
          <button
            type="button"
            data-tag={cat}
            class:list={[
              'cat-pill',
              {
                'acc-projects': cat === 'IA',
                'acc-blog': cat === 'Tech',
                'acc-about': cat === 'Lead',
                'acc-contact': cat === 'Business',
              },
            ]}
            aria-pressed="false"
          >
            <span>{BLOG_CATEGORIES[lang][cat]}</span>
          </button>
        ))
      }
    </div>

    {
      featured && (
        <section
          class="mt-12 border-t border-[color:var(--color-rule-strong)] pt-6"
          data-tags={featured.data.category}
        >
          <div class="flex items-baseline justify-between text-[10px] tracking-[0.14em] uppercase text-[color:var(--color-muted)] font-mono">
            <span>{tr.blogIndex.featured}</span>
            <span class="tnum">
              № {String(featured.data.number).padStart(2, '0')}
            </span>
          </div>
          <a
            href={localizedPath(lang, `/blog/${featured.id}`)}
            class="block mt-3 group"
          >
            <h2
              class="font-serif text-[30px] sm:text-[42px] leading-[1.08] tracking-[-0.015em] group-hover:text-[color:var(--a-blog)] transition-colors"
              style="font-family: var(--font-serif)"
            >
              {featured.data.title}
            </h2>
          </a>
          <div class="mt-4 flex items-center gap-4 text-[11px] tracking-[0.1em] uppercase text-[color:var(--color-muted)] font-mono">
            <time
              class="tnum acc-blog"
              datetime={toISODate(featured.data.publishedAt)}
            >
              {formatDateDotted(featured.data.publishedAt)}
            </time>
            <span aria-hidden="true">·</span>
            <CategoryPill
              category={featured.data.category}
              size="sm"
              lang={lang}
            />
            {featured.data.readingTime && (
              <>
                <span aria-hidden="true">·</span>
                <span class="tnum">{featured.data.readingTime} min</span>
              </>
            )}
          </div>
          <p class="mt-4 text-[15px] text-[#2a2622] leading-[1.75] max-w-[560px]">
            {featured.data.excerpt}
          </p>
        </section>
      )
    }

    <section class="mt-16">
      <div
        class="text-[10px] tracking-[0.14em] uppercase text-[color:var(--color-muted)] mb-3 font-mono"
      >
        {tr.blogIndex.archive}
      </div>
      <ul id="archive">
        {
          archive.map((post) => (
            <li
              class="py-5 border-t border-[color:var(--color-rule)]"
              data-tags={post.data.category}
            >
              <a
                href={localizedPath(lang, `/blog/${post.id}`)}
                class="grid grid-cols-[80px_1fr] sm:grid-cols-[110px_1fr_80px_60px] gap-3 sm:gap-5 items-baseline group"
              >
                <time
                  class="tnum text-[11px] tracking-[0.08em] uppercase acc-blog font-mono"
                  datetime={toISODate(post.data.publishedAt)}
                >
                  {formatDateDotted(post.data.publishedAt)}
                </time>
                <h3
                  class="font-serif text-[19px] sm:text-[23px] leading-[1.25] tracking-[-0.005em] col-span-2 sm:col-span-1 group-hover:text-[color:var(--a-blog)] transition-colors"
                  style="font-family: var(--font-serif)"
                >
                  {post.data.title}
                </h3>
                <span class="hidden sm:inline">
                  <CategoryPill
                    category={post.data.category}
                    size="sm"
                    lang={lang}
                  />
                </span>
                {post.data.readingTime && (
                  <span class="hidden sm:inline text-[11px] tnum text-right text-[color:var(--color-muted)]">
                    {post.data.readingTime} min
                  </span>
                )}
              </a>
            </li>
          ))
        }
        <li class="border-t border-[color:var(--color-rule)]"></li>
      </ul>
      <p
        id="empty"
        class="hidden mt-6 text-[13px] text-[color:var(--color-muted)]"
        aria-live="polite"
      >
        {tr.blogIndex.empty}
      </p>
    </section>
  </main>

  <Footer variant="blog" maxWidth="820px" lang={lang} />
</SiteLayout>

<style is:global>
  .cat-pill {
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    border: 1px solid currentColor;
    border-radius: 999px;
    padding: 2px 8px;
    cursor: pointer;
    font-family: var(--font-mono);
  }
  .chip-active {
    background: currentColor;
  }
  .chip-active > span {
    color: var(--color-bg);
  }
</style>

<script>
  const filters = document.getElementById('filters');
  const posts = document.querySelectorAll<HTMLLIElement>(
    '#archive li[data-tags]'
  );
  const empty = document.getElementById('empty');
  if (filters && empty) {
    filters.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      const btn = target.closest<HTMLButtonElement>('button[data-tag]');
      if (!btn) return;
      filters.querySelectorAll('button').forEach((x) => {
        x.classList.remove('chip-active');
        x.setAttribute('aria-pressed', 'false');
      });
      btn.classList.add('chip-active');
      btn.setAttribute('aria-pressed', 'true');

      const tag = btn.dataset.tag!;
      let shown = 0;
      posts.forEach((li) => {
        const tags = li.dataset.tags ?? '';
        const show = tag === 'all' || tags.includes(tag);
        li.classList.toggle('hidden', !show);
        if (show) shown++;
      });
      empty.classList.toggle('hidden', shown > 0);
    });
  }
</script>
