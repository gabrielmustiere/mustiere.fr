---
import SiteLayout from '@layouts/SiteLayout.astro';
import BlogSection from '@components/home/BlogSection.astro';
import ProjectsSection from '@components/home/ProjectsSection.astro';
import ContactSection from '@components/home/ContactSection.astro';
import CvSection from '@components/home/CvSection.astro';
import StructuredData from '@components/seo/StructuredData.astro';
import HeroFR from '@components/i18n/home/hero/fr.astro';
import HeroEN from '@components/i18n/home/hero/en.astro';
import { profilePageSchema } from '@/utils/schema';
import { SITE } from '@/consts';
import { useTranslations, localizedPath } from '@/i18n/utils';
import { routePath } from '@/i18n/routes';
import type { Lang } from '@/i18n/config';
import type { AstroComponentFactory } from 'astro/runtime/server/index.js';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const tr = useTranslations(lang);
const parcoursHref = localizedPath(lang, routePath('parcours', lang));

const HERO: Record<Lang, AstroComponentFactory> = {
  fr: HeroFR,
  en: HeroEN,
};
const Hero = HERO[lang];
---

<SiteLayout
  description={tr.site.description}
  type="website"
  current="home"
  lang={lang}
>
  <StructuredData slot="head" schemas={[profilePageSchema(lang)]} />

  <main
    id="main"
    class="mx-auto px-6 sm:px-10 pt-8 sm:pt-18 pb-16 sm:pb-28"
    style="max-width: var(--w-home)"
  >
    <header id="about" data-key="about">
      <Hero />

      <dl
        class="mt-8 grid grid-cols-1 sm:grid-cols-2 sm:gap-x-10 text-[13px] text-[color:var(--color-muted)] max-w-[640px]"
      >
        <div
          class="flex justify-between border-b border-[color:var(--color-rule)] py-2"
        >
          <dt>{tr.home.about.experienceLabel}</dt>
          <dd class="tnum acc-about">
            {tr.home.about.experienceValue}
          </dd>
        </div>
        <div
          class="flex justify-between border-b border-[color:var(--color-rule)] py-2"
        >
          <dt>{tr.home.about.rolesLabel}</dt>
          <dd class="text-[color:var(--color-ink)]">CTO · Lead · IC</dd>
        </div>
        <div
          class="flex justify-between border-b border-[color:var(--color-rule)] py-2"
        >
          <dt>{tr.home.about.locationLabel}</dt>
          <dd class="text-[color:var(--color-ink)]">
            {tr.home.about.location}
          </dd>
        </div>
        <div
          class="flex justify-between border-b border-[color:var(--color-rule)] py-2"
        >
          <dt>{tr.home.about.availabilityLabel}</dt>
          <dd class="acc-about">{tr.home.about.availability}</dd>
        </div>
      </dl>

      <div class="mt-8 flex items-center gap-5 text-[13px] flex-wrap">
        <a href={parcoursHref} class="link-u acc-about font-medium">
          {tr.home.about.moreCta} →
        </a>
        <span class="text-[color:var(--color-rule-strong)]" aria-hidden="true"
          >·</span
        >
        <a href="#contact" class="link-u text-[color:var(--color-ink)]">
          {tr.home.contact.contactCta}
        </a>
        <span class="text-[color:var(--color-rule-strong)]" aria-hidden="true"
          >·</span
        >
        <a href="#cv" class="link-u text-[color:var(--color-muted)]">
          {tr.home.contact.cvCta}
        </a>
        <span class="text-[color:var(--color-rule-strong)]" aria-hidden="true"
          >·</span
        >
        <a
          href={SITE.author.github}
          target="_blank"
          rel="noopener"
          class="link-u text-[color:var(--color-muted)]"
          aria-label="GitHub"
        >
          GitHub
        </a>
        <a
          href={SITE.author.linkedin}
          target="_blank"
          rel="noopener"
          class="link-u text-[color:var(--color-muted)]"
          aria-label="LinkedIn"
        >
          LinkedIn
        </a>
      </div>
    </header>

    <BlogSection lang={lang} />
    <ProjectsSection lang={lang} />
    <ContactSection lang={lang} />
    <CvSection lang={lang} />
  </main>
</SiteLayout>

<style>
  .about-portrait {
    width: 96px;
    height: 96px;
    border-radius: 999px;
    object-fit: cover;
    border: 1px solid var(--color-rule-strong);
    display: block;
  }
</style>
