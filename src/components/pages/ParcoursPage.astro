---
import SiteLayout from '@layouts/SiteLayout.astro';
import StructuredData from '@components/seo/StructuredData.astro';
import Footer from '@components/layout/Footer.astro';
import {
  parcoursPageSchema,
  parcoursFaqSchema,
  breadcrumbSchema,
} from '@/utils/schema';
import { SITE } from '@/consts';
import {
  localizedPath,
  useTranslations,
  otherLang as otherLangOf,
} from '@/i18n/utils';
import { routePath } from '@/i18n/routes';
import { parcoursContent } from '@/i18n/content/parcours';
import HeroFR from '@components/i18n/parcours/hero/fr.astro';
import HeroEN from '@components/i18n/parcours/hero/en.astro';
import ExpPassionBarbecueFR from '@components/i18n/parcours/experience-passion-barbecue/fr.astro';
import ExpPassionBarbecueEN from '@components/i18n/parcours/experience-passion-barbecue/en.astro';
import ExpProgicarFR from '@components/i18n/parcours/experience-progicar/fr.astro';
import ExpProgicarEN from '@components/i18n/parcours/experience-progicar/en.astro';
import ExpXlSoftFR from '@components/i18n/parcours/experience-xl-soft/fr.astro';
import ExpXlSoftEN from '@components/i18n/parcours/experience-xl-soft/en.astro';
import ExtSymfonyFR from '@components/i18n/parcours/expertise-symfony/fr.astro';
import ExtSymfonyEN from '@components/i18n/parcours/expertise-symfony/en.astro';
import ExtSyliusFR from '@components/i18n/parcours/expertise-sylius/fr.astro';
import ExtSyliusEN from '@components/i18n/parcours/expertise-sylius/en.astro';
import ExtProductBuilderFR from '@components/i18n/parcours/expertise-product-builder/fr.astro';
import ExtProductBuilderEN from '@components/i18n/parcours/expertise-product-builder/en.astro';
import type { Lang } from '@/i18n/config';
import type { AstroComponentFactory } from 'astro/runtime/server/index.js';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const tr = useTranslations(lang);
const content = parcoursContent[lang];

const HERO: Record<Lang, AstroComponentFactory> = { fr: HeroFR, en: HeroEN };
const EXPERIENCE_BODIES: Record<
  'passion-barbecue' | 'progicar' | 'xl-soft',
  Record<Lang, AstroComponentFactory>
> = {
  'passion-barbecue': { fr: ExpPassionBarbecueFR, en: ExpPassionBarbecueEN },
  progicar: { fr: ExpProgicarFR, en: ExpProgicarEN },
  'xl-soft': { fr: ExpXlSoftFR, en: ExpXlSoftEN },
};
const EXPERTISE_BODIES: Record<
  'symfony' | 'sylius' | 'product-builder',
  Record<Lang, AstroComponentFactory>
> = {
  symfony: { fr: ExtSymfonyFR, en: ExtSymfonyEN },
  sylius: { fr: ExtSyliusFR, en: ExtSyliusEN },
  'product-builder': { fr: ExtProductBuilderFR, en: ExtProductBuilderEN },
};
const Hero = HERO[lang];
const ExpPassionBarbecue = EXPERIENCE_BODIES['passion-barbecue'][lang];
const ExpProgicar = EXPERIENCE_BODIES['progicar'][lang];
const ExpXlSoft = EXPERIENCE_BODIES['xl-soft'][lang];
const ExtSymfony = EXPERTISE_BODIES['symfony'][lang];
const ExtSylius = EXPERTISE_BODIES['sylius'][lang];
const ExtProductBuilder = EXPERTISE_BODIES['product-builder'][lang];

const homeUrl = `${SITE.url}${localizedPath(lang, '/')}`;
const parcoursUrl = `${SITE.url}${localizedPath(lang, routePath('parcours', lang))}`;
const otherLangHref = localizedPath(
  otherLangOf(lang),
  routePath('parcours', otherLangOf(lang))
);

const breadcrumbs = [
  { name: tr.breadcrumb.home, url: homeUrl },
  { name: tr.parcours.headTitle, url: parcoursUrl },
];

const title = tr.parcours.headTitleSeo;
const description = tr.parcours.headDescription;
---

<SiteLayout
  title={tr.parcours.headTitle}
  description={description}
  type="website"
  current="about"
  lang={lang}
  otherLangHref={otherLangHref}
>
  <StructuredData
    slot="head"
    schemas={[
      parcoursPageSchema(lang, title, description),
      parcoursFaqSchema(lang),
      breadcrumbSchema(breadcrumbs),
    ]}
  />

  <main
    id="main"
    class="mx-auto px-6 sm:px-10 pt-8 sm:pt-18 pb-16 sm:pb-28"
    style="max-width: var(--w-home)"
  >
    <header class="mt-10 sm:mt-24">
      <div class="text-[11px] tracking-[0.12em] uppercase font-mono acc-about">
        <span class="acc-dot"></span>{tr.parcours.eyebrow}
      </div>
      <Hero />

      <div class="mt-6 sm:mt-8 flex items-center gap-5 text-[13px] flex-wrap">
        <a
          href={`mailto:${SITE.author.email}`}
          class="link-u text-[color:var(--color-ink)]"
        >
          {tr.parcours.contactCta}
        </a>
        <span class="text-[color:var(--color-rule-strong)]" aria-hidden="true"
          >·</span
        >
        <a href="/cv.pdf" class="link-u text-[color:var(--color-muted)]">
          {tr.parcours.cvCta}
        </a>
        <span class="text-[color:var(--color-rule-strong)]" aria-hidden="true"
          >·</span
        >
        <a
          href={localizedPath(lang, '/')}
          class="link-u text-[color:var(--color-muted)]"
        >
          {tr.parcours.backHome}
        </a>
      </div>
    </header>

    <hr
      class="mt-14 sm:mt-24 border-0 border-t border-[color:var(--color-rule)]"
    />

    <section id="experiences">
      <div class="mt-14 sm:mt-24 flex items-baseline gap-4">
        <span
          class="tnum text-[11px] tracking-[0.12em] uppercase font-mono acc-about"
        >
          <span class="acc-dot"></span>§ 01
        </span>
        <h2
          class="font-serif text-[28px] sm:text-[36px] leading-[1.1] tracking-[-0.01em]"
          style="font-family: var(--font-serif)"
        >
          {tr.parcours.experiencesTitle}
        </h2>
      </div>

      <ol class="mt-8 space-y-12 max-w-[720px]">
        {
          (() => {
            const xp = content.experiences[0];
            return (
              <li>
                <div class="text-[11px] tracking-[0.1em] uppercase font-mono text-[color:var(--color-muted)]">
                  {xp.period}
                </div>
                <h3
                  class="font-serif mt-1 text-[22px] sm:text-[26px] tracking-[-0.005em]"
                  style="font-family: var(--font-serif)"
                >
                  {xp.title}
                </h3>
                <div class="mt-1 text-[12.5px] text-[color:var(--color-muted)] font-mono">
                  {xp.context}
                </div>
                <ul class="mt-3 space-y-2 text-[14.5px] text-[#2a2622] leading-[1.65] list-disc pl-5">
                  {xp.anytimeBullets?.map((bullet) => (
                    <li>
                      {bullet.map((seg) =>
                        typeof seg === 'string' ? seg : <em>{seg.em}</em>
                      )}
                    </li>
                  ))}
                </ul>
              </li>
            );
          })()
        }

        <li>
          <div
            class="text-[11px] tracking-[0.1em] uppercase font-mono text-[color:var(--color-muted)]"
          >
            {content.experiences[1].period}
          </div>
          <h3
            class="font-serif mt-1 text-[22px] sm:text-[26px] tracking-[-0.005em]"
            style="font-family: var(--font-serif)"
          >
            {content.experiences[1].title}
          </h3>
          <div
            class="mt-1 text-[12.5px] text-[color:var(--color-muted)] font-mono"
          >
            {content.experiences[1].context}
          </div>
          <div
            class="mt-3 space-y-3 text-[14.5px] text-[#2a2622] leading-[1.65]"
          >
            <ExpPassionBarbecue />
          </div>
        </li>

        <li>
          <div
            class="text-[11px] tracking-[0.1em] uppercase font-mono text-[color:var(--color-muted)]"
          >
            {content.experiences[2].period}
          </div>
          <h3
            class="font-serif mt-1 text-[22px] sm:text-[26px] tracking-[-0.005em]"
            style="font-family: var(--font-serif)"
          >
            {content.experiences[2].title}
          </h3>
          <div
            class="mt-1 text-[12.5px] text-[color:var(--color-muted)] font-mono"
          >
            {content.experiences[2].context}
          </div>
          <div
            class="mt-3 space-y-3 text-[14.5px] text-[#2a2622] leading-[1.65]"
          >
            <ExpProgicar />
          </div>
        </li>

        <li>
          <div
            class="text-[11px] tracking-[0.1em] uppercase font-mono text-[color:var(--color-muted)]"
          >
            {content.experiences[3].period}
          </div>
          <h3
            class="font-serif mt-1 text-[22px] sm:text-[26px] tracking-[-0.005em]"
            style="font-family: var(--font-serif)"
          >
            {content.experiences[3].title}
          </h3>
          <div
            class="mt-1 text-[12.5px] text-[color:var(--color-muted)] font-mono"
          >
            {content.experiences[3].context}
          </div>
          <div
            class="mt-3 space-y-3 text-[14.5px] text-[#2a2622] leading-[1.65]"
          >
            <ExpXlSoft />
          </div>
        </li>
      </ol>
    </section>

    <section id="expertises">
      <div class="mt-14 sm:mt-24 flex items-baseline gap-4">
        <span
          class="tnum text-[11px] tracking-[0.12em] uppercase font-mono acc-about"
        >
          <span class="acc-dot"></span>§ 02
        </span>
        <h2
          class="font-serif text-[28px] sm:text-[36px] leading-[1.1] tracking-[-0.01em]"
          style="font-family: var(--font-serif)"
        >
          {tr.parcours.expertisesTitle}
        </h2>
      </div>

      <div class="mt-8 space-y-12 max-w-[720px]">
        <div>
          <h3
            class="font-serif text-[22px] sm:text-[24px] tracking-[-0.005em]"
            style="font-family: var(--font-serif)"
          >
            {content.expertises[0].title}
          </h3>
          <p class="mt-3 text-[14.5px] text-[#2a2622] leading-[1.65]">
            <ExtSymfony />
          </p>
        </div>

        <div>
          <h3
            class="font-serif text-[22px] sm:text-[24px] tracking-[-0.005em]"
            style="font-family: var(--font-serif)"
          >
            {content.expertises[1].title}
          </h3>
          <p class="mt-3 text-[14.5px] text-[#2a2622] leading-[1.65]">
            <ExtSylius />
          </p>
        </div>

        <div>
          <h3
            class="font-serif text-[22px] sm:text-[24px] tracking-[-0.005em]"
            style="font-family: var(--font-serif)"
          >
            {content.expertises[2].title}
          </h3>
          <div
            class="mt-3 space-y-3 text-[14.5px] text-[#2a2622] leading-[1.65]"
          >
            <ExtProductBuilder />
          </div>
        </div>

        <div>
          <h3
            class="font-serif text-[22px] sm:text-[24px] tracking-[-0.005em]"
            style="font-family: var(--font-serif)"
          >
            {content.architectureTitle}
          </h3>
          <ul
            class="mt-3 space-y-2 text-[14.5px] text-[#2a2622] leading-[1.65] list-disc pl-5"
          >
            {content.architectureBullets.map((b) => <li>{b}</li>)}
          </ul>
        </div>

        <div>
          <h3
            class="font-serif text-[22px] sm:text-[24px] tracking-[-0.005em]"
            style="font-family: var(--font-serif)"
          >
            {tr.parcours.securityTitle}
          </h3>
          <ul
            class="mt-3 space-y-2 text-[14.5px] text-[#2a2622] leading-[1.65] list-disc pl-5"
          >
            {
              content.securityBullets.map((b) => (
                <li>
                  <strong>{b.strong}</strong> {b.suffix}
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </section>

    <section id="modes">
      <div class="mt-14 sm:mt-24 flex items-baseline gap-4">
        <span
          class="tnum text-[11px] tracking-[0.12em] uppercase font-mono acc-about"
        >
          <span class="acc-dot"></span>§ 03
        </span>
        <h2
          class="font-serif text-[28px] sm:text-[36px] leading-[1.1] tracking-[-0.01em]"
          style="font-family: var(--font-serif)"
        >
          {tr.parcours.modesTitle}
        </h2>
      </div>

      <div
        class="mt-8 grid grid-cols-1 sm:grid-cols-2 gap-x-10 gap-y-8 max-w-[720px]"
      >
        {
          content.interventionModes.map((mode) => (
            <div>
              <h3 class="text-[15px] font-medium text-[color:var(--color-ink)]">
                {mode.title}
              </h3>
              <p class="mt-2 text-[14px] text-[#2a2622] leading-[1.65]">
                {mode.body}
              </p>
            </div>
          ))
        }
      </div>
    </section>

    <section id="localisation">
      <div class="mt-14 sm:mt-24 flex items-baseline gap-4">
        <span
          class="tnum text-[11px] tracking-[0.12em] uppercase font-mono acc-about"
        >
          <span class="acc-dot"></span>§ 04
        </span>
        <h2
          class="font-serif text-[28px] sm:text-[36px] leading-[1.1] tracking-[-0.01em]"
          style="font-family: var(--font-serif)"
        >
          {content.locationSectionTitle}
        </h2>
      </div>

      <dl
        class="mt-8 grid grid-cols-1 sm:grid-cols-2 sm:gap-x-10 text-[13px] text-[color:var(--color-muted)] max-w-[720px]"
      >
        <div
          class="flex justify-between border-b border-[color:var(--color-rule)] py-2"
        >
          <dt>{content.location[0].term}</dt>
          <dd class="text-[color:var(--color-ink)]">
            {content.location[0].description}
          </dd>
        </div>
        <div
          class="flex justify-between border-b border-[color:var(--color-rule)] py-2"
        >
          <dt>{content.location[1].term}</dt>
          <dd class="text-[color:var(--color-ink)]">
            {content.location[1].description}
          </dd>
        </div>
        <div
          class="flex justify-between border-b border-[color:var(--color-rule)] py-2"
        >
          <dt>{content.location[2].term}</dt>
          <dd class="text-[color:var(--color-ink)]">
            {content.location[2].description}
          </dd>
        </div>
        <div
          class="flex justify-between border-b border-[color:var(--color-rule)] py-2"
        >
          <dt>{content.location[3].term}</dt>
          <dd class="acc-about">{content.location[3].description}</dd>
        </div>
        <div
          class="flex justify-between border-b border-[color:var(--color-rule)] py-2"
        >
          <dt>Email</dt>
          <dd>
            <a
              href={`mailto:${SITE.author.email}`}
              class="link-u text-[color:var(--color-ink)]"
            >
              {SITE.author.email}
            </a>
          </dd>
        </div>
        <div
          class="flex justify-between border-b border-[color:var(--color-rule)] py-2"
        >
          <dt>LinkedIn</dt>
          <dd>
            <a
              href={SITE.author.linkedin}
              target="_blank"
              rel="noopener"
              class="link-u text-[color:var(--color-ink)]"
            >
              gabrielmustiere
            </a>
          </dd>
        </div>
      </dl>
    </section>

    <section id="faq">
      <div class="mt-14 sm:mt-24 flex items-baseline gap-4">
        <span
          class="tnum text-[11px] tracking-[0.12em] uppercase font-mono acc-about"
        >
          <span class="acc-dot"></span>§ 05
        </span>
        <h2
          class="font-serif text-[28px] sm:text-[36px] leading-[1.1] tracking-[-0.01em]"
          style="font-family: var(--font-serif)"
        >
          {tr.parcours.faqTitle}
        </h2>
      </div>

      <dl class="mt-8 space-y-8 max-w-[720px]">
        {
          content.faq.map((item) => (
            <div>
              <dt
                class="font-serif text-[18px] sm:text-[20px] tracking-[-0.005em]"
                style="font-family: var(--font-serif)"
              >
                {item.q}
              </dt>
              <dd class="mt-2 text-[14.5px] text-[#2a2622] leading-[1.7]">
                {item.a}
              </dd>
            </div>
          ))
        }
      </dl>
    </section>

    <section
      class="mt-14 sm:mt-24 border-t border-[color:var(--color-rule-strong)] pt-8 flex items-center justify-between gap-6 flex-wrap"
    >
      <div>
        <div
          class="text-[11px] tracking-[0.12em] uppercase acc-about font-mono"
        >
          <span class="acc-dot"></span>§ 06 ·{' '}
          {content.ctaEyebrow}
        </div>
        <h2
          class="font-serif mt-1 text-[28px] sm:text-[36px] tracking-[-0.01em]"
          style="font-family: var(--font-serif)"
        >
          {content.ctaTitle}
        </h2>
        <p
          class="mt-2 text-[14px] text-[color:var(--color-muted)] max-w-[480px]"
        >
          {content.ctaBody}
        </p>
      </div>
      <a
        href={`mailto:${SITE.author.email}`}
        class="inline-flex items-center gap-2 text-[13px] border px-4 py-2 rounded-full hover:bg-white transition acc-about"
        style="border-color: var(--a-about)"
      >
        <span>{content.ctaButton}</span>
        <span class="font-mono text-[11px]">→</span>
      </a>
    </section>

    <Footer variant="home" lang={lang} />
  </main>
</SiteLayout>
