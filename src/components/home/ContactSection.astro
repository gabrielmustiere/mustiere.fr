---
import SectionHead from '../ui/SectionHead.astro';
import { SITE } from '../../consts';
---

<section data-key="contact" id="contact">
  <SectionHead number="04" title="Contact" accent="contact" />
  <p
    class="mt-4 text-[15px] text-[#2a2622] leading-[1.75] max-w-[520px]"
  >
    Missions, audits, sparring : un mail suffit. Je réponds sous 48h,
    jamais aux sollicitations commerciales.
  </p>
  <dl class="mt-6 text-[15px]">
    <div
      class="flex items-baseline gap-4 border-t border-[color:var(--color-rule)] py-3"
    >
      <dt
        class="text-[11px] tracking-[0.1em] uppercase w-20 text-[color:var(--color-muted)] font-mono"
      >
        Email
      </dt>
      <dd>
        <a
          href={`mailto:${SITE.author.email}`}
          class="link-u acc-contact">{SITE.author.email}</a
        >
      </dd>
    </div>
    <div
      class="flex items-baseline gap-4 border-t border-[color:var(--color-rule)] py-3"
    >
      <dt
        class="text-[11px] tracking-[0.1em] uppercase w-20 text-[color:var(--color-muted)] font-mono"
      >
        LinkedIn
      </dt>
      <dd>
        <a
          href={SITE.author.linkedin}
          target="_blank"
          rel="noopener"
          class="link-u">/in/gmustiere</a
        >
      </dd>
    </div>
    <div
      class="flex items-baseline gap-4 border-t border-b border-[color:var(--color-rule)] py-3"
    >
      <dt
        class="text-[11px] tracking-[0.1em] uppercase w-20 text-[color:var(--color-muted)] font-mono"
      >
        GitHub
      </dt>
      <dd>
        <a
          href={SITE.author.github}
          target="_blank"
          rel="noopener"
          class="link-u">@gmustiere</a
        >
      </dd>
    </div>
  </dl>
</section>
