---
import SectionHead from '../ui/SectionHead.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects')).sort(
  (a, b) => a.data.order - b.data.order
);
---

<section data-key="projects" id="projects">
  <SectionHead number="03" title="Side projects" accent="projects" />

  <div class="mt-8 space-y-10">
    {
      projects.map((project) => (
        <article>
          <div
            class="placeholder-stripe rounded-md aspect-[21/9]"
            role="presentation"
            aria-hidden="true"
          />
          <div class="mt-3 flex items-baseline justify-between gap-4">
            <h3
              class="font-serif text-[22px] sm:text-[26px] tracking-[-0.005em]"
              style="font-family: var(--font-serif)"
            >
              {project.data.title}
            </h3>
            <span class="text-[11px] tracking-[0.1em] uppercase tnum text-[color:var(--color-muted)] font-mono">
              {project.data.status}
            </span>
          </div>
          <div class="text-[11px] tracking-[0.1em] uppercase text-[color:var(--color-muted)] font-mono">
            {project.data.kind} · {project.data.year}
          </div>
          <p class="mt-2 text-[14px] text-[#2a2622] leading-[1.65] max-w-[520px]">
            {project.data.excerpt}
          </p>
        </article>
      ))
    }
  </div>
</section>

<style>
  .placeholder-stripe {
    background-image: repeating-linear-gradient(
      135deg,
      #ebe7de 0 6px,
      #e4dfd4 6px 12px
    );
  }
</style>
