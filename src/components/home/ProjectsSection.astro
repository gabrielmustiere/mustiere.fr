---
import SectionHead from '@components/ui/SectionHead.astro';
import { getCollection } from 'astro:content';
import { getLangFromUrl, useTranslations, localizedPath } from '@/i18n/utils';
import type { Lang } from '@/i18n/config';
import { isPublished } from '@/utils/content';

interface Props {
  lang?: Lang;
}

const lang = Astro.props.lang ?? getLangFromUrl(Astro.url);
const tr = useTranslations(lang);

const projects = (
  await getCollection('projects', (entry) => isPublished(entry, lang))
).sort((a, b) => a.data.order - b.data.order);
---

<section data-key="projects" id="projects">
  <SectionHead number="02" title={tr.home.projects.title} accent="projects" />

  <div class="mt-8 space-y-10">
    {
      projects.map((project) => (
        <a
          href={localizedPath(lang, `/projects/${project.id}`)}
          class="block group project-card"
        >
          <article>
            <div class="flex items-baseline justify-between gap-4">
              <h3
                class="font-serif text-[22px] sm:text-[26px] tracking-[-0.005em] group-hover:text-[color:var(--a-projects)] transition-colors"
                style="font-family: var(--font-serif)"
                transition:name={`project-title-${project.id}`}
              >
                {project.data.title}
              </h3>
              <span class="text-[11px] tracking-[0.1em] uppercase tnum text-[color:var(--color-muted)] font-mono">
                {project.data.status}
              </span>
            </div>
            <div class="text-[11px] tracking-[0.1em] uppercase text-[color:var(--color-muted)] font-mono">
              {project.data.kind} · {project.data.year}
            </div>
            <p class="mt-2 text-[14px] text-[#2a2622] leading-[1.65] max-w-[520px]">
              {project.data.excerpt}
            </p>
            <span class="mt-3 inline-flex items-center gap-1 text-[10px] tracking-[0.14em] uppercase font-mono text-[color:var(--color-muted)] group-hover:text-[color:var(--a-projects)] transition-colors">
              <span>{tr.home.projects.readDetail}</span>
              <span aria-hidden="true" class="arrow">
                →
              </span>
            </span>
          </article>
        </a>
      ))
    }
  </div>
</section>

<style>
  .project-card {
    text-decoration: none;
    color: inherit;
  }
  .project-card .arrow {
    transition: transform 0.15s ease;
  }
  .project-card:hover .arrow {
    transform: translateX(2px);
  }
</style>
