---
import SectionHead from '@components/ui/SectionHead.astro';
import ArticleCard from '@components/ui/ArticleCard.astro';
import { getCollection } from 'astro:content';
import { getLangFromUrl, useTranslations, localizedPath } from '@/i18n/utils';
import type { Lang } from '@/i18n/config';
import { isPublished } from '@/utils/content';

interface Props {
  lang?: Lang;
}

const lang = Astro.props.lang ?? getLangFromUrl(Astro.url);
const tr = useTranslations(lang);

const posts = (await getCollection('blog', (entry) => isPublished(entry, lang)))
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime())
  .slice(0, 4);
---

<section data-key="blog" id="blog">
  <SectionHead number="01" title={tr.home.blog.title} accent="blog" />
  <p class="mt-4 text-[14px] text-[color:var(--color-muted)] max-w-[480px]">
    {tr.home.blog.intro}
  </p>

  <ul class="mt-8">
    {
      posts.map((post, i) => (
        <li class="py-4 border-t border-[color:var(--color-rule)]">
          <ArticleCard
            entry={post}
            variant="sm"
            lang={lang}
            loading={i === 0 ? 'eager' : 'lazy'}
            fetchpriority={i === 0 ? 'high' : undefined}
            showCover={false}
          />
        </li>
      ))
    }
    <li class="border-t border-[color:var(--color-rule)]"></li>
  </ul>
  <div class="mt-6">
    <a href={localizedPath(lang, '/blog')} class="text-[13px] acc-blog link-u">
      {tr.home.blog.seeAll} →
    </a>
  </div>

  <figure class="mt-10">
    <figcaption
      class="text-[11px] tracking-[0.12em] uppercase mb-2 text-[color:var(--color-muted)] font-mono"
    >
      {tr.home.blog.excerptCaption}
    </figcaption>
    <pre
      class="code-block"><code>{`// tiny scoring loop
for (const c of suite) {
  const out = await model.run(c.input)
  const s   = score(out, c.expected)
  yield { id: c.id, score: s }
}`}</code></pre>
  </figure>
</section>
